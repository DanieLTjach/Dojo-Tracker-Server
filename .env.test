# Authentication settings (24 hour validity)
AUTH_INIT_DATA_VALIDITY_SECONDS=86400

FRONTEND_URL=http://localhost:3000

# Telegram
BOT_URL=https://t.me/test_bot_link_for_testing
BOT_TOKEN=test_bot_token_for_testing
TELEGRAM_NOTIFICATIONS_ENABLED=false
