# Example Environment Configuration
# Copy this file to .env and update the values as needed

NODE_ENV=development # or production
PORT=3000
DB_PATH=./db/data/data.db

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRY=7d

# Authentication settings
AUTH_INIT_DATA_VALIDITY_SECONDS=3600

# Tournament Mode (for offline tournaments without Telegram authentication)
# WARNING: Only enable for controlled tournament environments!
TOURNAMENT_MODE=false
TOURNAMENT_USER_ID=1

FRONTEND_URL=http://localhost:3000

# Telegram
BOT_URL=https://t.me/your_bot_link_here
BOT_TOKEN=your_bot_token_here
GLOBAL_LOGS_CHAT_ID=your_global_logs_chat_id_here
# optional
# GLOBAL_ERROR_LOGS_TOPIC_ID=your_global_error_logs_topic_id_here
# GLOBAL_USER_LOGS_TOPIC_ID=your_global_user_logs_topic_id_here
# GLOBAL_GAME_LOGS_TOPIC_ID=your_global_game_logs_topic_id_here
# GLOBAL_CLUB_LOGS_TOPIC_ID=your_global_club_logs_topic_id_here